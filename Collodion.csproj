<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <AssemblyName>collodion</AssemblyName>
    <!-- Set this to your Vintage Story install directory. -->
    <VINTAGE_STORY_PATH Condition=" '$(VINTAGE_STORY_PATH)' == '' "></VINTAGE_STORY_PATH>
  </PropertyGroup>

  <PropertyGroup Condition="Exists('$(MSBuildProjectDirectory)\.env')">
    <_EnvText>$([System.IO.File]::ReadAllText('$(MSBuildProjectDirectory)\.env'))</_EnvText>
    <VINTAGE_STORY_PATH Condition=" '$(VINTAGE_STORY_PATH)' == '' ">$([System.Text.RegularExpressions.Regex]::Match('$(_EnvText)', '(?m)^VINTAGE_STORY_PATH\s*=\s*(.+)$').Groups[1].Value.Trim())</VINTAGE_STORY_PATH>
    <MODS_PATH Condition=" '$(MODS_PATH)' == '' ">$([System.Text.RegularExpressions.Regex]::Match('$(_EnvText)', '(?m)^MODS_PATH\s*=\s*(.+)$').Groups[1].Value.Trim())</MODS_PATH>
    <SECONDARY_MODS_PATH Condition=" '$(SECONDARY_MODS_PATH)' == '' ">$([System.Text.RegularExpressions.Regex]::Match('$(_EnvText)', '(?m)^SECONDARY_MODS_PATH\s*=\s*(.+)$').Groups[1].Value.Trim())</SECONDARY_MODS_PATH>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>false</DebugSymbols>
    <DebugType>none</DebugType>
    <GenerateDependencyFile>false</GenerateDependencyFile>
  </PropertyGroup>

  <ItemGroup>
    <!-- <PackageReference Include="Vintagestory.API" Version="1.21.6" /> -->
  </ItemGroup>

  <!-- Referenced DLLs from the game installation -->
  <ItemGroup>
    <Reference Include="VintagestoryAPI">
      <HintPath>$(VINTAGE_STORY_PATH)\VintagestoryAPI.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="VintagestoryLib">
      <HintPath>$(VINTAGE_STORY_PATH)\VintagestoryLib.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="protobuf-net">
      <HintPath>$(VINTAGE_STORY_PATH)\Lib\protobuf-net.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="SkiaSharp">
      <HintPath>$(VINTAGE_STORY_PATH)\Lib\SkiaSharp.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="OpenTK.Graphics">
      <HintPath>$(VINTAGE_STORY_PATH)\Lib\OpenTK.Graphics.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="OpenTK.Core">
      <HintPath>$(VINTAGE_STORY_PATH)\Lib\OpenTK.Core.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(VINTAGE_STORY_PATH)\Lib\0Harmony.dll</HintPath>
      <Private>False</Private>
    </Reference>
    <Reference Include="Newtonsoft.Json">
      <HintPath>$(VINTAGE_STORY_PATH)\Lib\Newtonsoft.Json.dll</HintPath>
      <Private>False</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Include="modinfo.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="assets\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Embed GPU exposure shaders so GpuExposureAccumulator can load them at runtime. -->
  <ItemGroup>
    <EmbeddedResource Include="src\Features\Exposure\Accumulator\Shaders\gpu-exposure-accum.frag.glsl">
      <LogicalName>Collodion.gpu-exposure-accum.frag.glsl</LogicalName>
    </EmbeddedResource>
    <EmbeddedResource Include="src\Features\Exposure\Accumulator\Shaders\gpu-exposure-develop.frag.glsl">
      <LogicalName>Collodion.gpu-exposure-develop.frag.glsl</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Don't compile or deploy reference repos/tools checked into the workspace. -->
  <ItemGroup>
    <Compile Remove="reference\**\*.cs" />
    <Compile Remove="tests\**\*.cs" />
    <Compile Remove="obj\**\*.cs" />
    <Compile Remove="bin\**\*.cs" />
    <EmbeddedResource Remove="reference\**\*" />
    <None Remove="reference\**\*" />
  </ItemGroup>


  <Target Name="ZipOutputToMods" AfterTargets="Build" Condition=" '$(Configuration)' == 'Debug' And ('$(MODS_PATH)' != '' Or '$(SECONDARY_MODS_PATH)' != '') ">
    <Exec Command="powershell -NoProfile -Command &quot;&amp; { Add-Type -AssemblyName System.IO.Compression; Add-Type -AssemblyName System.IO.Compression.FileSystem; $out = [System.IO.Path]::GetFullPath('$(TargetDir)'); if (-not $out) { exit 1 }; if (-not $out.EndsWith([System.IO.Path]::DirectorySeparatorChar)) { $out += [System.IO.Path]::DirectorySeparatorChar }; $info = Get-Content '$(MSBuildProjectDirectory)\modinfo.json' | ConvertFrom-Json; $modId = $info.modid; $ver = $info.version; if (-not $modId) { $modId = 'collodion' }; if (-not $ver) { $ver = 'dev' }; $zipName = ($modId + '-' + $ver + '-' + '$(Configuration)' + '.zip'); $localZip = Join-Path $out $zipName; if (Test-Path $localZip) { Remove-Item $localZip -Force }; Remove-Item -Path (Join-Path $out '*.pdb'), (Join-Path $out '*.deps.json') -Force -ErrorAction SilentlyContinue; $stream = [System.IO.File]::Open($localZip, [System.IO.FileMode]::Create); $archive = New-Object System.IO.Compression.ZipArchive($stream, ([System.IO.Compression.ZipArchiveMode]::Create), $false); try { Get-ChildItem -Path $out -Recurse -File | Where-Object { $_.FullName -ne $localZip } | ForEach-Object { $entryName = $_.FullName.Substring($out.Length).Replace([char][System.IO.Path]::DirectorySeparatorChar, [char]'/'); [System.IO.Compression.ZipFileExtensions]::CreateEntryFromFile($archive, $_.FullName, $entryName, [System.IO.Compression.CompressionLevel]::Optimal) | Out-Null } } finally { $archive.Dispose(); $stream.Dispose() }; foreach ($dest in @('$(MODS_PATH)', '$(SECONDARY_MODS_PATH)') | Where-Object { $_ -ne '' }) { if (-not (Test-Path $dest)) { New-Item -ItemType Directory -Path $dest | Out-Null }; Copy-Item $localZip (Join-Path $dest $zipName) -Force } }&quot;" />
  </Target>

</Project>