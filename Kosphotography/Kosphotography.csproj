<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <AssemblyName>kosphotography</AssemblyName>
    <VINTAGE_STORY_PATH Condition=" '$(VINTAGE_STORY_PATH)' == '' "></VINTAGE_STORY_PATH>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>false</DebugSymbols>
    <DebugType>none</DebugType>
    <GenerateDependencyFile>false</GenerateDependencyFile>
  </PropertyGroup>

  <!-- Core class library (Photochemistry.Core.dll is copied into this project's output). -->
  <ItemGroup>
    <ProjectReference Include="..\Core\Core.csproj" />
  </ItemGroup>

  <!-- Package this head's modinfo.json into output. -->
  <ItemGroup>
    <None Include="modinfo.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Link shared assets from Core (photochemistry domain) into this project's output under assets\. -->
  <ItemGroup>
    <None Include="..\Core\assets\**\*">
      <Link>assets\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- This head's own asset overlay (kosphotography domain: timed/automatic cameras, recipes, lang). -->
  <ItemGroup>
    <None Include="assets\**\*">
      <Link>assets\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="obj\**\*.cs" />
    <Compile Remove="bin\**\*.cs" />
  </ItemGroup>

  <!-- Package the Debug build as a mod zip into this project's bin/ folder (not the game mods folder).
       Old zips for this modid are cleared first so a version bump leaves no orphans. -->
  <Target Name="ZipDebugBuild" AfterTargets="Build" Condition=" '$(Configuration)' == 'Debug' ">
    <Exec Command="powershell -NoProfile -Command &quot;&amp; { Add-Type -AssemblyName System.IO.Compression; Add-Type -AssemblyName System.IO.Compression.FileSystem; $src = [System.IO.Path]::GetFullPath('$(TargetDir)'); if (-not $src.EndsWith([System.IO.Path]::DirectorySeparatorChar)) { $src += [System.IO.Path]::DirectorySeparatorChar }; $info = Get-Content '$(MSBuildProjectDirectory)\modinfo.json' | ConvertFrom-Json; $modId = $info.modid; if (-not $modId) { $modId = '$(AssemblyName)' }; $ver = $info.version; if (-not $ver) { $ver = 'dev' }; $destDir = Join-Path '$(MSBuildProjectDirectory)' 'bin'; if (-not (Test-Path $destDir)) { New-Item -ItemType Directory -Path $destDir | Out-Null }; Get-ChildItem -Path $destDir -Filter ($modId + '-*-Debug.zip') -ErrorAction SilentlyContinue | Remove-Item -Force; $zip = Join-Path $destDir ($modId + '-' + $ver + '-Debug.zip'); $stream = [System.IO.File]::Open($zip, [System.IO.FileMode]::Create); $archive = New-Object System.IO.Compression.ZipArchive($stream, ([System.IO.Compression.ZipArchiveMode]::Create), $false); try { Get-ChildItem -Path $src -Recurse -File | Where-Object { $_.Extension -ne '.pdb' -and $_.Extension -ne '.zip' -and $_.Name -notlike '*.deps.json' } | ForEach-Object { $entryName = $_.FullName.Substring($src.Length).Replace([char][System.IO.Path]::DirectorySeparatorChar, [char]'/'); [System.IO.Compression.ZipFileExtensions]::CreateEntryFromFile($archive, $_.FullName, $entryName, [System.IO.Compression.CompressionLevel]::Optimal) | Out-Null } } finally { $archive.Dispose(); $stream.Dispose() } }&quot;" />
  </Target>

</Project>
