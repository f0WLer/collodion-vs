# Copy this file to .env and fill in your local paths.
# .env is gitignored; .env.example is tracked.

# Vintage Story install directory (contains VintagestoryAPI.dll / VintagestoryLib.dll)
VINTAGE_STORY_PATH=C:\Program Files (x86)\Vintagestory

# Vintage Story mods folder (where debug builds are deployed as zips).
# Leave blank to skip auto-deploy on build.
MODS_PATH=C:\Users\YourName\AppData\Roaming\VintagestoryData\Mods

# Optional secondary mods folder (e.g. a second install or dedicated server).
# Leave blank to skip.
SECONDARY_MODS_PATH=

# Optional: path to a locally built or extracted ConfigLib.dll (github.com/maltiez2/vsmod_configlib),
# only needed to build/test the optional ConfigLib GUI integration. Leave blank to skip - Core builds
# fine without it, the integration file is just excluded from compilation.
CONFIGLIB_PATH=
