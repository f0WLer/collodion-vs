<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <AssemblyName>collodion</AssemblyName>
    <VINTAGE_STORY_PATH Condition=" '$(VINTAGE_STORY_PATH)' == '' "></VINTAGE_STORY_PATH>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>false</DebugSymbols>
    <DebugType>none</DebugType>
    <GenerateDependencyFile>false</GenerateDependencyFile>
  </PropertyGroup>

  <!-- Core class library (Photocore.dll is copied into this project's output). -->
  <ItemGroup>
    <ProjectReference Include="..\Core\Core.csproj" />
  </ItemGroup>

  <!-- Package modinfo.json into output. -->
  <ItemGroup>
    <None Include="modinfo.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- Link shared assets from Core (photocore domain) into this project's output under assets\. -->
  <ItemGroup>
    <None Include="..\Core\assets\**\*">
      <Link>assets\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <!-- This head's own asset overlay (collodion domain), layered on top of the shared Core assets.
       Drop baseline-only assets under assets\collodion\ (or any non-photocore domain) here. -->
  <ItemGroup>
    <None Include="assets\**\*">
      <Link>assets\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="obj\**\*.cs" />
    <Compile Remove="bin\**\*.cs" />
  </ItemGroup>

  <!-- Package the build as a mod zip into this project's bin/ folder, then also copy it into each game
       Mods folder (MODS_PATH and SECONDARY_MODS_PATH from .env) for testing. Debug builds get a "-Debug"
       suffix so they don't collide with a Release zip of the same version; Release builds ship as plain
       modid-version.zip. Old zips for this modid+configuration are cleared first in every location so a
       version bump leaves no orphans. Both heads' zips land in Mods/ (they can't run together — disable
       one in-game). A destination is skipped when unset/missing.

       SECONDARY_MODS_PATH matters for multiplayer testing: the second client instance loads from there,
       and deploying to only MODS_PATH left it running a stale build while the host ran the new one. -->
  <Target Name="ZipBuild" AfterTargets="Build" Condition=" '$(Configuration)' == 'Debug' Or '$(Configuration)' == 'Release' ">
    <Exec Command="powershell -NoProfile -Command &quot;&amp; { Add-Type -AssemblyName System.IO.Compression; Add-Type -AssemblyName System.IO.Compression.FileSystem; $src = [System.IO.Path]::GetFullPath('$(TargetDir)'); if (-not $src.EndsWith([System.IO.Path]::DirectorySeparatorChar)) { $src += [System.IO.Path]::DirectorySeparatorChar }; $info = Get-Content '$(MSBuildProjectDirectory)\modinfo.json' | ConvertFrom-Json; $modId = $info.modid; if (-not $modId) { $modId = '$(AssemblyName)' }; $ver = $info.version; if (-not $ver) { $ver = 'dev' }; $isDebug = '$(Configuration)' -eq 'Debug'; $suffix = if ($isDebug) { '-Debug' } else { '' }; $destDir = Join-Path '$(MSBuildProjectDirectory)' 'bin'; if (-not (Test-Path $destDir)) { New-Item -ItemType Directory -Path $destDir | Out-Null }; Get-ChildItem -Path $destDir -Filter ($modId + '-*.zip') -ErrorAction SilentlyContinue | Where-Object { $_.Name.EndsWith('-Debug.zip') -eq $isDebug } | Remove-Item -Force; $zip = Join-Path $destDir ($modId + '-' + $ver + $suffix + '.zip'); $stream = [System.IO.File]::Open($zip, [System.IO.FileMode]::Create); $archive = New-Object System.IO.Compression.ZipArchive($stream, ([System.IO.Compression.ZipArchiveMode]::Create), $false); try { Get-ChildItem -Path $src -Recurse -File | Where-Object { $_.Extension -ne '.pdb' -and $_.Extension -ne '.zip' -and $_.Name -notlike '*.deps.json' } | ForEach-Object { $entryName = $_.FullName.Substring($src.Length).Replace([char][System.IO.Path]::DirectorySeparatorChar, [char]'/'); [System.IO.Compression.ZipFileExtensions]::CreateEntryFromFile($archive, $_.FullName, $entryName, [System.IO.Compression.CompressionLevel]::Optimal) | Out-Null } } finally { $archive.Dispose(); $stream.Dispose() }; foreach ($modsPath in @('$(MODS_PATH)', '$(SECONDARY_MODS_PATH)')) { if ($modsPath -and (Test-Path $modsPath)) { Get-ChildItem -Path $modsPath -Filter ($modId + '-*.zip') -ErrorAction SilentlyContinue | Where-Object { $_.Name.EndsWith('-Debug.zip') -eq $isDebug } | Remove-Item -Force; Copy-Item -Path $zip -Destination (Join-Path $modsPath ($modId + '-' + $ver + $suffix + '.zip')) -Force } } }&quot;" />
  </Target>

</Project>
